external
runs

# librelane writes its run/ artifacts and pulls Verilog into the design dir;
# only the config.json is canonical and committed under flows/librelane/.
flows/librelane/*/runs
flows/librelane/*/binner.v
*.pdf

# Pareto plots are regenerable from the runs/ data via plot_pareto.py;
# only the CSV table is canonical and committed.
results/*.png

# Python bytecode cache
__pycache__/
